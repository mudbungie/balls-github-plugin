#!/usr/bin/env bash
# Git pre-commit hook for balls-plugin-github.
#
# Blocks any commit that:
#   1. Has clippy warnings
#   2. Contains a Rust source file >= 300 lines
#   3. Tests fail
#   4. Line coverage < 100%
#
# To install: scripts/install-hooks.sh

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# Git invokes a hook with GIT_DIR, GIT_INDEX_FILE and friends exported.
# They leak into every `git` subprocess the gates spawn: the plugins'
# git-spawning tests (`git_ops`, `shellback`/`store`) `git init` a tempdir
# then `git add`/`commit`, which those vars would silently retarget onto
# THIS repo's index (GIT_DIR beats the child's chosen cwd). Scrub git's
# repo-local env so clippy, the tests and tarpaulin run as from a clean shell.
unset $(git rev-parse --local-env-vars)

echo "pre-commit: clippy..."
cargo clippy --workspace --all-targets -- -D warnings 2>&1

echo "pre-commit: line lengths..."
"$ROOT/scripts/check-line-lengths.sh"

echo "pre-commit: tests..."
cargo test --workspace --quiet 2>&1

echo "pre-commit: coverage..."
"$ROOT/scripts/check-coverage.sh"

echo "pre-commit: OK."
